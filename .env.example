# --- Tebekaye Phase 0 — copy to .env / .env.local and fill values ---
# Never commit real secrets.

# App URLs (local dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
API_PUBLIC_URL=http://localhost:8000

# Database (use docker-compose Postgres or Supabase)
DATABASE_URL=postgresql://tebekaye:tebekaye_dev@localhost:5432/tebekaye

# Redis (optional Phase 1+ workers)
REDIS_URL=redis://localhost:6379/0

# Supabase (if using Supabase Auth + Storage + pgvector)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Object storage (S3-compatible) — or use Supabase Storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=

# LLM providers (at least one for Phase 2+)
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=

# Vector store: leave empty if using pgvector in Postgres; or Chroma URL
CHROMA_HOST=
CHROMA_PORT=

# Stripe (global SaaS billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_BUSINESS=

# LakiPay (optional regional sandbox — wire in Phase 4)
LAKIPAY_API_KEY=
LAKIPAY_WEBHOOK_SECRET=

# FastAPI / Next server-to-server (generate a long random string)
INTERNAL_API_SECRET=

# --- Premade test users (REMOVE before production) ---
# After migrations: cd apps/api && python scripts/seed_local_dev.py
#   dev@local.tebekaye     / devlocal123
#   test@tebekaye.local    / TestAccount123!
# Login/signup pages list these when `npm run dev`. Delete users from DB + strip seed script for prod.
